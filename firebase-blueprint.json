{
  "entities": {
    "Category": {
      "title": "Category",
      "description": "Category for products",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "slug", "createdAt"]
    },
    "Product": {
      "title": "Product",
      "description": "Stores information for basic products",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "slug": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "integer" },
        "categoryId": { "type": "string" },
        "isActive": { "type": "boolean" },
        "statusBadge": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "slug", "price", "categoryId", "isActive", "createdAt", "updatedAt"]
    },
    "ProductVariant": {
      "title": "Product Variant",
      "description": "A variant for a product",
      "type": "object",
      "properties": {
        "productId": { "type": "string" },
        "name": { "type": "string" },
        "value": { "type": "string" },
        "sku": { "type": "string" },
        "additionalPrice": { "type": "integer" },
        "stockQuantity": { "type": "integer" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["productId", "name", "value", "sku", "additionalPrice", "stockQuantity", "createdAt", "updatedAt"]
    },
    "ProductImage": {
      "title": "Product Image",
      "description": "Images for products/variants",
      "type": "object",
      "properties": {
        "productId": { "type": "string" },
        "variantId": { "type": "string" },
        "imageUrl": { "type": "string" },
        "displayOrder": { "type": "integer" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["productId", "imageUrl", "displayOrder", "createdAt"]
    }
  },
  "firestore": {
    "/categories/{categoryId}": {
      "schema": { "$ref": "#/entities/Category" },
      "description": "Categories for the store"
    },
    "/products/{productId}": {
      "schema": { "$ref": "#/entities/Product" },
      "description": "Products of the store"
    },
    "/product_variants/{variantId}": {
      "schema": { "$ref": "#/entities/ProductVariant" },
      "description": "Product variants"
    },
    "/product_images/{imageId}": {
      "schema": { "$ref": "#/entities/ProductImage" },
      "description": "Product images"
    }
  }
}
